{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@tauri-apps/api/*": ["node_modules/@tauri-apps/api/*"]
    },
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },

  "include": [
    "**/*.ts",
    "**/*.tsx",
    "./globals.d.ts"
, "../../cognition/observers/projection-witness.ts"  ],

  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".vite",
    "**/*.js"
  ]
}