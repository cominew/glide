{
  "productName": "Glide",
  "version": "0.1.0",
  "identifier": "com.glide.os",
  "build": {
    "frontendDist": "../apps/dashboard/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix apps/dashboard",
    "beforeBuildCommand": "npm run build --prefix apps/dashboard"
  },
  "app": {
"windows": [
  {
    "label": "main",
    "title": "Glide",
    "width": 1200,
    "height": 800,
    "decorations": false,
    "transparent": true,
    "alwaysOnTop": false,
    "skipTaskbar": true,
    "center": true,
    "resizable": false,
    "visible": false,
    "devtools": true
  }
],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["msi", "nsis", "dmg", "appimage", "deb"]
  }
}