{
  "productName": "Glide",
  "version": "0.1.0",
  "identifier": "com.glide.os",
  "build": {
    "beforeDevCommand": "npm run dev --prefix apps/dashboard",  
    "beforeBuildCommand": "npm run build --prefix apps/dashboard",  
    "devUrl": "http://localhost:5173",  
    "frontendDist": "../apps/dashboard/dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "Glide Pet",
        "width": 1280,
        "height": 800,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true
  }
}