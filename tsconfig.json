{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true
  },
  "include": [
    "start.ts",
    "runtime/**/*",
    "kernel/**/*",
    "skills/**/*",
    "tools/**/*",
    "apps/server/**/*",
    "globals.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "apps/dashboard"
  ]
}
